// Code for to determine conservation of species
// Inlet + Outlet + Wall + FluidDomain = 0

inletFlux
{
	type            surfaceFieldValue;
	libs            ("libfieldFunctionObjects.so");
	regionType      patch;			// patch of interest
	name            inlet;
	
	writeControl    timeStep;		// write per time step
	writeInterval   1;				// every time step

	operation       areaIntegrate;
	fields          (wallFlux);		// field of interest
	
	log             true;
	writeFields     false;
	writeToFile     true;
}

